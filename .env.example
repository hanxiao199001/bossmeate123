# ========================================
# BossMate 环境变量配置
# 复制此文件为 .env 并填入实际值
# ========================================

# 服务端口
PORT=3000
API_PREFIX=/api/v1

# 数据库 (PostgreSQL)
DATABASE_URL=postgresql://bossmate:your_password@localhost:5432/bossmate
DATABASE_POOL_SIZE=10

# Redis 缓存
REDIS_URL=redis://localhost:6379

# JWT 认证
JWT_SECRET=your-jwt-secret-min-32-chars-for-production
JWT_EXPIRES_IN=7d

# 凭证加密 (可选，默认使用 JWT_SECRET)
CREDENTIALS_KEY=your-credentials-encryption-key-min-32-chars

# AI 模型配置 - 贵模型
ANTHROPIC_API_KEY=your-anthropic-api-key
OPENAI_API_KEY=your-openai-api-key

# AI 模型配置 - 便宜模型
DEEPSEEK_API_KEY=your-deepseek-api-key
QWEN_API_KEY=your-qwen-api-key

# 模型路由默认策略
DEFAULT_EXPENSIVE_MODEL=claude-sonnet-4-20250514
DEFAULT_CHEAP_MODEL=deepseek-chat
MODEL_CIRCUIT_BREAKER_THRESHOLD=5

# T2 模型直映射 — TaskType → 具体模型名
DEEPSEEK_MODEL_CHAT=deepseek-chat
DEEPSEEK_MODEL_REASONER=deepseek-reasoner
QWEN_MODEL_PLUS=qwen-plus
QWEN_MODEL_MAX=qwen-max

# 知识库 (LanceDB)
LANCEDB_PATH=./data/lancedb

# 文件存储
UPLOAD_DIR=./data/uploads
MAX_FILE_SIZE=50mb

# Springer Nature API（免费申请: https://dev.springernature.com）
SPRINGER_API_KEY=your-springer-api-key
# Springer 代理（如需翻墙访问 link.springer.com）
# SPRINGER_PROXY=http://127.0.0.1:7890

# 日志
LOG_LEVEL=info
LOG_DIR=./logs

# AI 销售对话模块（后端 + 前端双开关，默认关闭）
SALES_AGENT_ENABLED=false
VITE_SALES_ENABLED=false
